<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="100%" height="100%">
  <!-- Background rustic table -->
  <rect width="400" height="300" fill="#E8D8C8"/>
  <path d="M 0,50 L 400,10" stroke="#DFCCA2" stroke-width="4" stroke-dasharray="10 20" opacity="0.3"/>
  <path d="M 0,150 L 400,110" stroke="#DFCCA2" stroke-width="4" stroke-dasharray="10 20" opacity="0.3"/>
  <path d="M 0,250 L 400,210" stroke="#DFCCA2" stroke-width="4" stroke-dasharray="10 20" opacity="0.3"/>

  <!-- Banana Leaf underliner -->
  <path d="M 50,150 C 40,80 180,30 320,60 C 360,110 340,240 280,260 C 180,290 60,225 50,150 Z" fill="#2E7D32"/>
  <path d="M 50,150 L 280,260" stroke="#1B5E20" stroke-width="2" opacity="0.6"/>
  <!-- Leaf Vein Detail Lines -->
  <path d="M 120,110 L 100,50" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 160,126 L 150,60" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 210,147 L 210,75" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 260,167 L 275,100" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 150,180 L 130,240" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 200,201 L 190,265" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>
  <path d="M 240,218 L 245,275" stroke="#1B5E20" stroke-width="1" opacity="0.4"/>

  <!-- Traditional Craft Plate shadow -->
  <ellipse cx="205" cy="165" rx="105" ry="85" fill="#000000" opacity="0.15"/>

  <!-- Clay/Ceramic Plate -->
  <ellipse cx="200" cy="160" rx="100" ry="80" fill="#8D6E63"/>
  <ellipse cx="200" cy="160" rx="90" ry="72" fill="#704F43"/>
  <ellipse cx="200" cy="160" rx="88" ry="70" fill="#A1887F"/>

  <!-- COCONUT RICE (Santan Rice) Mound -->
  <ellipse cx="200" cy="155" rx="55" ry="45" fill="#000000" opacity="0.1"/>
  <path d="M 148,155 C 145,120 180,105 200,105 C 220,105 255,120 252,155 C 250,180 225,195 200,195 C 175,195 150,180 148,155 Z" fill="#FDFEFE"/>
  <!-- Grain textures on Rice -->
  <ellipse cx="195" cy="130" rx="3" ry="1.5" fill="#EAECEE"/>
  <ellipse cx="180" cy="140" rx="2" ry="4" fill="#EAECEE" transform="rotate(30 180 140)"/>
  <ellipse cx="215" cy="135" rx="4" ry="2" fill="#EAECEE" transform="rotate(-15 215 135)"/>
  <ellipse cx="225" cy="155" rx="3" ry="1.5" fill="#EAECEE" transform="rotate(45 225 155)"/>
  <ellipse cx="170" cy="160" rx="4" ry="2" fill="#EAECEE"/>
  <ellipse cx="200" cy="175" rx="3" ry="1.5" fill="#EAECEE"/>
  <!-- Pandan Leaf garnish on Rice -->
  <path d="M 200,110 L 195,95 L 205,100 Z" fill="#1B5E20"/>
  <path d="M 202,110 L 210,92 L 206,104 Z" fill="#2E7D32"/>

  <!-- SPICY RED SAMBAL (Glossy rich dark-red chili paste) -->
  <ellipse cx="140" cy="180" rx="25" ry="20" fill="#000000" opacity="0.1"/>
  <path d="M 120,175 C 115,160 140,150 155,160 C 165,165 168,185 155,195 C 142,202 122,192 120,175 Z" fill="#990000"/>
  <path d="M 125,178 C 122,170 135,165 145,170 C 150,172 150,182 145,188 C 140,192 128,186 125,178 Z" fill="#7A0000"/>
  <!-- Sambal shine stars/circles (chili head glint) -->
  <circle cx="148" cy="166" r="3" fill="#FF8A80" opacity="0.8"/>
  <circle cx="138" cy="182" r="2" fill="#FF8A80" opacity="0.6"/>
  <!-- Chili seed specs in Sambal -->
  <ellipse cx="132" cy="175" rx="1" ry="1.5" fill="#FFE082" transform="rotate(45 132 175)"/>
  <ellipse cx="145" cy="179" rx="1.5" ry="1" fill="#FFE082" transform="rotate(-30 145 179)"/>
  <ellipse cx="152" cy="172" rx="1" ry="1.5" fill="#FFE082" transform="rotate(20 152 172)"/>

  <!-- FRIED EGG (Telur Mata Kerbau, crispy bubbly brown edges) -->
  <ellipse cx="250" cy="170" rx="30" ry="22" fill="#000000" opacity="0.1"/>
  <!-- White part of Fried Egg -->
  <path d="M 225,170 C 220,155 240,145 260,150 C 275,153 285,165 280,180 C 275,192 255,195 240,188 C 230,182 226,178 225,170 Z" fill="#F4F6F6"/>
  <!-- Egg crispy brown bubble spots and borders -->
  <path d="M 230,158 C 228,155 233,153 236,155 Z" stroke="#8D6E63" stroke-width="1.5" fill="none"/>
  <path d="M 276,182 C 278,185 274,188 271,186 Z" stroke="#8D6E63" stroke-width="1.5" fill="none"/>
  <!-- Egg Yolk (Plump and runny glint) -->
  <circle cx="255" cy="168" r="10" fill="#FFB300"/>
  <path d="M 248,165 C 248,161 254,160 258,162 C 263,164 263,172 258,175 C 253,177 248,171 248,165 Z" fill="#FFA000"/>
  <circle cx="251" cy="164" r="2.5" fill="#FFFFFF" opacity="0.8"/>

  <!-- FRESH CUCUMBER SLICES (Timun) -->
  <!-- Cucumber 1 -->
  <g transform="translate(195, 210) rotate(-40)">
    <ellipse cx="0" cy="0" rx="15" ry="8" fill="#1B5E20"/>
    <ellipse cx="0" cy="0" rx="13" ry="6" fill="#81C784"/>
    <ellipse cx="0" cy="0" rx="10" ry="4" fill="#C8E6C9"/>
    <!-- tiny cucumber seeds -->
    <circle cx="-4" cy="-1" r="0.6" fill="#FFFFFF" opacity="0.9"/>
    <circle cx="0" cy="1" r="0.6" fill="#FFFFFF" opacity="0.9"/>
    <circle cx="4" cy="-1" r="0.6" fill="#FFFFFF" opacity="0.9"/>
  </g>
  <!-- Cucumber 2 -->
  <g transform="translate(170, 215) rotate(-15)">
    <ellipse cx="0" cy="0" rx="15" ry="8" fill="#1B5E20"/>
    <ellipse cx="0" cy="0" rx="13" ry="6" fill="#81C784"/>
    <ellipse cx="0" cy="0" rx="10" ry="4" fill="#C8E6C9"/>
    <circle cx="-3" cy="1" r="0.6" fill="#FFFFFF" opacity="0.9"/>
    <circle cx="2" cy="-1" r="0.6" fill="#FFFFFF" opacity="0.9"/>
  </g>

  <!-- ROASTED PEANUTS (Kacang) & CRISPY ANCHOVIES (Ikan Bilis) -->
  <!-- Small container/pile -->
  <g transform="translate(245, 120)">
    <ellipse cx="0" cy="0" rx="15" ry="12" fill="#000000" opacity="0.08"/>
    <!-- Peanuts (brown ovals) -->
    <ellipse cx="-4" cy="-3" rx="4" ry="2.5" fill="#A1887F" transform="rotate(25 -4 -3)"/>
    <ellipse cx="5" cy="-5" rx="3.5" ry="2.2" fill="#8D6E63" transform="rotate(-15 5 -5)"/>
    <ellipse cx="3" cy="3" rx="4.2" ry="2.6" fill="#A1887F" transform="rotate(45 3 3)"/>
    <ellipse cx="-6" cy="5" rx="3.8" ry="2.4" fill="#8D6E63" transform="rotate(-40 -6 5)"/>
    <!-- Ikan Bilis (anchovies, silver ovals with eyes) -->
    <path d="M -10,0 C -5,-3 2,-1 8,-4" stroke="#B0BEC5" stroke-width="2.2" stroke-linecap="round" fill="none"/>
    <circle cx="7" cy="-4" r="0.5" fill="#37474F"/>
    
    <path d="M -8,-8 C -3,-6 3,-8 6,-5" stroke="#CFD8DC" stroke-width="2" stroke-linecap="round" fill="none"/>
    <circle cx="5" cy="-5" r="0.5" fill="#37474F"/>

    <path d="M -5,4 C 0,5 6,2 10,5" stroke="#90A4AE" stroke-width="2.4" stroke-linecap="round" fill="none"/>
    <circle cx="9" cy="5" r="0.5" fill="#37474F"/>
  </g>

  <!-- Traditional Nasi Lemak Title block -->
  <rect x="110" y="20" width="180" height="24" rx="12" fill="#1B5E20" opacity="0.85"/>
  <text x="200" y="35" text-anchor="middle" fill="#FFFFFF" font-family="'Inter', sans-serif" font-size="10" font-weight="950" letter-spacing="1">NASI LEMAK BIASA</text>
</svg>
